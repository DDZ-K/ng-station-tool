{
  "enableImageCopy": true,
  "enableCloudRelease": true,
  "watchRoot": "D:\\WatchRoot",
  "outputRoot": "D:\\OutputRoot",
  "imageExtensions": [ ".jpg", ".jpeg", ".png", ".gif", ".bmp", ".webp" ],
  "sizeStableChecks": 2,
  "sizeStableIntervalMs": 200,
  "retryDelayMs": 150,
  "maxRetries": 10,
  "readyBudgetMs": 1000,
  "folderSettleMs": 800,
  "batchMaxWaitMs": 15000,
  "debounceMs": 300,
  "minImageBytes": 32,
  "onlyDirectImages": true,
  "skipIfSameSizeExists": true,
  "useDateFolders": true,
  "dateFolderFrom": "Now",
  "dateFolderStyle": "ymd",
  "ngImageRoot": "D:\\OutputRoot",
  "cloudLogRoot": "D:\\CloudResult",
  "cloudLogArchiveRoot": "D:\\CloudResult\\done",
  "logExtensions": [ ".log", ".txt" ],
  "resultLineNumber": 2,
  "okTokens": [ "OK", "PASS" ],
  "nokTokens": [ "NOK", "NG", "FAIL" ],
  "resultMatchIgnoreCase": true,
  "dmcFromImage": "FileStem",
  "dmcFromLog": "FileStem",
  "pendingTimeoutSec": 120,
  "enqueueFromNgImageWatch": false,
  "enqueueFromImageCopyFolderName": true,
  "logReadyBudgetMs": 2000,
  "keyPressDelayMs": 50,
  "activateWindowDelayMs": 150,
  "okKey": "NumPad9",
  "nokKey": "NumPad7",
  "keyRepeatCount": 1,
  "targetWindowTitleContains": "",
  "targetProcessName": "",
  "requireNumPad": true,
  "autoStartOnLaunch": false,
  "maxLogLines": 500,
  "uiRefreshMs": 500
}
